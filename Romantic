<!DOCTYPE html>
<html>
<head>
  <title>Farah’s Romantic Journey</title>
  <style>
    body {
      font-family: 'Georgia', serif;
      text-align: center;
      background: linear-gradient(to bottom, #ffdde1, #ee9ca7);
      color: #4a2c2a;
      margin: 0;
      padding: 0;
    }
    h1 {
      font-family: 'Brush Script MT', cursive;
      font-size: 3em;
      margin-top: 40px;
    }
    .choice {
      margin: 20px;
      padding: 15px;
      background: #fff0f5;
      border: 2px solid #e75480;
      border-radius: 12px;
      cursor: pointer;
      transition: 0.3s;
      font-size: 1.2em;
    }
    .choice:hover {
      background: #ffe4e1;
      transform: scale(1.05);
    }
    #game {
      margin-top: 50px;
    }
    .fade {
      animation: fadeIn 2s;
    }
    @keyframes fadeIn {
      from {opacity: 0;}
      to {opacity: 1;}
    }
  </style>
</head>
<body>
  <h1>Farah’s Romantic Game 🌹</h1>
  <p class="fade">Every choice you make brings us closer to a magical evening...</p>

  <div id="game"></div>

  <script>
    const steps = [
      { text: "Choose your dream evening:", options: ["Under the stars ✨", "By candlelight 🕯️"] },
      { text: "Pick the mood:", options: ["Gentle romance 💕", "Playful mystery 🎭"] },
      { text: "Final step:", options: ["Follow your heart ❤️", "Trust the surprise 🌌"] }
    ];

    let currentStep = 0;

    function showStep() {
      const step = steps[currentStep];
      let html = `<p class="fade">${step.text}</p>`;
      step.options.forEach(opt => {
        html += `<div class="choice" onclick="nextStep()">${opt}</div>`;
      });
      document.getElementById("game").innerHTML = html;
    }

    function nextStep() {
      currentStep++;
      if (currentStep < steps.length) {
        showStep();
      } else {
        document.getElementById("game").innerHTML =
          "<h2 class='fade'>✨ Surprise! ✨</h2><p class='fade'>Farah, I’ve reserved us a romantic dinner at <b>Sud Restaurant, Lebanon</b> this Monday at 8 PM. 🌹</p>";
      }
    }

    showStep();
  </script>
</body>
</html>
